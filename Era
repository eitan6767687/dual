         if not State.autoPlayLeftEnabled then return end
         local c = LP.Character
         if not c then return end
         local h = c:FindFirstChild("HumanoidRootPart")
         local hum = c:FindFirstChildOfClass("Humanoid")
         if not h or not hum then return end
         -- Skip while ragdolled so natural gravity/falling works
         local st = hum:GetState()
         if st == Enum.HumanoidStateType.Physics or st == Enum.HumanoidStateType.Ragdoll
             or st == Enum.HumanoidStateType.FallingDown then return end
         if not _apBypassPart or _apBypassPart.Parent ~= c then _apCreateProxy() end
         local attack = math.clamp(State.autoPlayAttackSpeed, 20, 200)
         local ret = math.clamp(State.autoPlayReturnSpeed, 10, 200)
         local targetPos, speed
         -- L1ג†’L2 at attack speed; L3ג†’L4 at return speed.
         if     State.autoPlayPhaseL == 1 then targetPos = apGetWP("L1"); speed = attack
         elseif State.autoPlayPhaseL == 2 then targetPos = apGetWP("L2"); speed = attack
         elseif State.autoPlayPhaseL == 3 then targetPos = apGetWP("L3"); speed = ret
         elseif State.autoPlayPhaseL == 4 then targetPos = apGetWP("L4"); speed = ret
         end
         if targetPos then

 -- ============================================================
 -- CHROME METAL TEXT  ג€” UIStroke + UIGradient per label
 -- Each letter gets a metallic gradient outline whose bright
 -- "reflection band" continuously sweeps up/down like polished
 -- chrome under a moving light source.
 -- TextColor3 is shifted to bright silver-violet (metallic base).
 -- ============================================================
 local function addChromeText(lbl)
    if not lbl or not lbl.Parent then return end
    if lbl:FindFirstChild("_chromeStyled") then return end
    local ts = lbl.TextSize or 14
    if ts < 7 then return end

    local marker = Instance.new("BoolValue")
    marker.Name = "_chromeStyled"
    marker.Value = true
    marker.Parent = lbl

    -- BRUSHED SILVER: Horizontal gradient on each letter
    pcall(function()
        lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
        lbl.TextStrokeTransparency = 1
    end)

    -- Change font to FredokaOne (rounded bubble-style font)
    pcall(function() lbl.Font = Enum.Font.Bangers end)

    -- Single thin outline for subtle edge definition
    local outline = Instance.new("UIStroke")
    outline.Name = "ChromeOutline"
    outline.ApplyStrokeMode = Enum.ApplyStrokeMode.Contextual
    outline.Thickness = math.max(0.6, ts * 0.06)
    outline.Transparency = 0.35
    outline.Color = Color3.fromRGB(95, 100, 112)
    outline.Parent = lbl

    -- PURE LIQUID SILVER GRADIENT ג€” bright flowing silver, no warm tones
    local silver = Instance.new("UIGradient", lbl)
    silver.Name = "ChromeSilver"
    silver.Rotation = 90
    silver.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0.00, Color3.fromRGB(18,  20,  25)),
        ColorSequenceKeypoint.new(0.10, Color3.fromRGB(48,  52,  60)),
        ColorSequenceKeypoint.new(0.22, Color3.fromRGB(118, 122, 132)),
        ColorSequenceKeypoint.new(0.35, Color3.fromRGB(182, 186, 195)),
        ColorSequenceKeypoint.new(0.50, Color3.fromRGB(245, 248, 255)),
        ColorSequenceKeypoint.new(0.65, Color3.fromRGB(182, 186, 195)),
        ColorSequenceKeypoint.new(0.78, Color3.fromRGB(118, 122, 132)),
        ColorSequenceKeypoint.new(0.90, Color3.fromRGB(48,  52,  60)),
        ColorSequenceKeypoint.new(1.00, Color3.fromRGB(18,  20,  25)),

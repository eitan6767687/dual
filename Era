 -- One persistent listener ג€” wires every player now and any who join later,
 -- including their future respawns. Checks State.espEnabled each time.
 local function _wireESP(p)
         if p == LP then return end
         p.CharacterAdded:Connect(function()
             task.wait(0.15)
             if State.espEnabled then pcall(_espApply, p) end
         end)
     end
     for _, p in ipairs(Players:GetPlayers()) do _wireESP(p) end
     Players.PlayerAdded:Connect(function(p)
         _wireESP(p)
         task.wait(0.15)
         if State.espEnabled then pcall(_espApply, p) end
     end)


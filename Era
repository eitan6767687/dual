 -- MOBILE BUTTONS (each independently draggable)
 -- ============================================================
 local QW, QH, QG, QR = 100, 52, 8, 14   -- rounded-rectangle buttons
 local Q_OFF  = Color3.fromRGB(8, 8, 8)
 local Q_ON   = Color3.fromRGB(60, 60, 60)
 local Q_TEXT = Color3.fromRGB(255, 255, 255)

 -- 3-col ֳ— 3-row grid default, right side just above the Roblox jump button
 -- The jump button occupies roughly the bottom 130px on most devices, so
 -- we raise the grid so its bottom row clears that area.
 local function _mbPos(col, row)
     local gridW = 2*(QW+QG) - QG
     local gridH = 4*(QH+QG) - QG
     return UDim2.new(1, -(gridW + 14) + col*(QW+QG),
                      1, -(gridH + 130) + row*(QH+QG))
 end

 local function makeMobileBtn(label, defaultPos, isToggle, onAction)
     local frame = Instance.new("Frame", gui)
     frame.Size = UDim2.new(0, QW, 0, QH)
     frame.Position = defaultPos
     frame.BackgroundColor3 = Q_OFF
     frame.BorderSizePixel = 0
     frame.Active = true
     frame.ZIndex = 102
     mkCorner(frame, QR)

     -- Static silver stroke (no animation - only main window + steal bar animate)
     local stroke = Instance.new("UIStroke", frame)
     stroke.Color = Color3.fromRGB(140, 140, 140)
     stroke.Thickness = 1.5
     stroke.Transparency = 0.15

     local btn = Instance.new("TextButton", frame)
     btn.Size = UDim2.new(1, 0, 1, 0)
     btn.BackgroundTransparency = 1
     btn.Text = label
     btn.TextColor3 = Q_TEXT
     btn.Font = Enum.Font.Bangers
     btn.TextSize = 17
     btn.TextWrapped = true
     btn.LineHeight = 1.25
     btn.BorderSizePixel = 0
     btn.AutoButtonColor = false
     btn.ZIndex = 103

     local isOn = false
     btn.MouseButton1Click:Connect(function()
         if isToggle then
             isOn = not isOn
             TweenService:Create(frame, TweenInfo.new(0.15), {BackgroundColor3 = isOn and Q_ON or Q_OFF}):Play()
             if onAction then onAction(isOn) end
         else
             TweenService:Create(frame, TweenInfo.new(0.08), {BackgroundColor3 = Q_ON}):Play()
             task.delay(0.25, function()
                 TweenService:Create(frame, TweenInfo.new(0.15), {BackgroundColor3 = Q_OFF}):Play()
             end)
             if onAction then onAction() end
         end
     end)

     local function setter(s)
         isOn = s
         TweenService:Create(frame, TweenInfo.new(0.15), {BackgroundColor3 = s and Q_ON or Q_OFF}):Play()
     end

     makeDraggable(frame, btn)
     -- Save position when the user lifts finger/mouse after a drag
     btn.InputEnded:Connect(function(inp)
         if inp.UserInputType == Enum.UserInputType.MouseButton1
         or inp.UserInputType == Enum.UserInputType.Touch then
             task.spawn(saveConfig)
         end
     end)
     table.insert(_mobileButtons, frame)
     table.insert(_mobileBtnData, {label = label, frame = frame, defaultPos = defaultPos})

     -- Apply silver chrome to mobile button text
     task.delay(0.3, function()
         pcall(addChromeText, btn)
     end)

     return frame, setter
 end


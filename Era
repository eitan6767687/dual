         end
         if _defaultWaistC0 then
             local lt2   = c2:FindFirstChild("LowerTorso")
             local waist = lt2 and lt2:FindFirstChild("Waist")
             if waist then
                 waist.C0 = _defaultWaistC0 * CFrame.fromEulerAnglesYXZ(_currentTiltAngle * 0.60, 0, 0)
             end
         end
     end)

     Conns.aimbot = RunService.Heartbeat:Connect(function(dt)
         if not State.batAimbotToggled then return end

         local c    = _abGetChar()
         local hum  = _abGetHum()
         local root = _abGetRoot()
         if not c or not hum or not root then return end

         local st = hum:GetState()
         if st == Enum.HumanoidStateType.Physics
         or st == Enum.HumanoidStateType.Ragdoll
         or st == Enum.HumanoidStateType.FallingDown then return end

         -- Ensure proxy is live
         if not _abBypassPart or _abBypassPart.Parent ~= c then _abCreateProxy() end

         if not _batEquipped then
             _batEquipped = true
             pcall(ensureBatEquipped)
         end

         local target = getAutoBatTarget()
         if target and target.Parent then
             local targetVel = target.AssemblyLinearVelocity
             local aimPos    = target.Position + (targetVel * 0.31) + Vector3.new(0, AUTO_BAT_V_OFF, 0)

             hum.AutoRotate = false

             local rj = _abGetRootJoint(c)
             if rj and not _defaultRootJointC0 then _defaultRootJointC0 = rj.C0 end
             if not _defaultWaistC0 then
                 local lt2   = c:FindFirstChild("LowerTorso")
                 local waist = lt2 and lt2:FindFirstChild("Waist")
                 if waist then _defaultWaistC0 = waist.C0 end
             end

             -- Tilt: 85% of vertical angle, lerp 14
             local toLook   = aimPos - root.Position
             local flatDist = Vector3.new(toLook.X, 0, toLook.Z).Magnitude
             local rawPitch = math.clamp(math.atan2(toLook.Y, math.max(flatDist, 0.1)), -math.rad(85), math.rad(85))
             local tPitch   = rawPitch * 0.85
             _currentTiltAngle = _currentTiltAngle + (tPitch - _currentTiltAngle) * math.min(1, 14 * dt)

             -- Yaw rotation with boost for large angles
             local look     = aimPos - root.Position
             local flatLook = Vector3.new(look.X, 0, look.Z)
             if look.Magnitude > 0.01 and flatLook.Magnitude > 0.01 then
                 local targetYaw = math.deg(math.atan2(-flatLook.X, -flatLook.Z))
                 local yawDelta  = (targetYaw - root.Orientation.Y + 180) % 360 - 180
                 local absYaw    = math.abs(yawDelta)
                 local boost     = 1 + 4 * math.clamp((absYaw - 30) / 150, 0, 1)
                 local yawRate   = math.clamp(math.rad(yawDelta) * AUTO_BAT_TURN_SPEED * boost, -AUTO_BAT_MAX_TURN * boost, AUTO_BAT_MAX_TURN * boost)
                 local angLerp   = math.min((30 + 70 * math.clamp((absYaw - 30) / 150, 0, 1)) * dt, 1)
                 pcall(function()
                     root.AssemblyAngularVelocity = root.AssemblyAngularVelocity:Lerp(Vector3.new(0, yawRate, 0), angLerp)
                 end)
             else
                 pcall(function() root.AssemblyAngularVelocity = Vector3.zero end)
             end

             -- Movement: separate horizontal + vertical velocities via proxy
             local dir      = look.Magnitude > 0.01 and look.Unit or Vector3.zero
             local standPos = aimPos - (dir * AUTO_BAT_DIST)
             local moveDir  = standPos - root.Position
             local hDir     = Vector3.new(moveDir.X, 0, moveDir.Z)
             local hVel     = hDir.Magnitude > 0.1 and hDir.Unit * AUTO_BAT_SPEED or Vector3.zero
             local vVel     = math.abs(moveDir.Y) > 0.1
                              and Vector3.new(0, math.sign(moveDir.Y) * AUTO_BAT_VERT_SPEED, 0)
                              or  Vector3.new(0, -2, 0)
             if _abBypassPart then _abBypassPart.AssemblyLinearVelocity = hVel + vVel end
             if hDir.Magnitude > 0.5 then hum:Move(hDir.Unit, false) end

             if State.autoSwingEnabled and (root.Position - target.Position).Magnitude < 6 then
                 local bat = findBat()
                 if bat then pcall(function() bat:Activate() end) end
             end
         else
             hum.AutoRotate = true
             pcall(function() root.AssemblyAngularVelocity = Vector3.zero end)
             if _abBypassPart then _abBypassPart.AssemblyLinearVelocity = Vector3.zero end
         end
     end)
 end

 function stopBatAimbot()
     pcall(function() RunService:UnbindFromRenderStep("_abTilt") end)
     if Conns.aimbot then Conns.aimbot:Disconnect(); Conns.aimbot = nil end
     _batEquipped   = false

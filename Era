        elseif kc==Keys.guiHide then
            if isKb then
                State.guiVisible=not State.guiVisible; mainOuter.Visible=State.guiVisible
                if _G.GreenDuelsQAHide then pcall(_G.GreenDuelsQAHide, not State.guiVisible) end

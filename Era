    if autoRightEnabled then autoRightEnabled = false; stopAutoRight(); if autoRightSetVisual then autoRightSetVisual(false) end end
    autoBatEquippedThisRun = false
    autoBatEnabled = true
end

local function disableAutoBat()
    autoBatEnabled = false
    autoBatEquippedThisRun = false

-- KEYBIND LISTENER (PC style)
-- ============================================================
UIS.InputBegan:Connect(function(input, gpe)
    if _anyKeyListening then return end
    if input.UserInputType == Enum.UserInputType.Keyboard then
        if gpe or UIS:GetFocusedTextBox() then return end
    end
    if not isGamepadInput(input) then
        if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
    end
    if not isBindableInput(input) then return end
    local kc = input.KeyCode
    if kbMatch(KB.LaggerToggle, kc) then toggleLaggerMode()
    elseif kbMatch(KB.SpeedToggle, kc) then toggleCarryMode()
    elseif kbMatch(KB.DropBrainrot, kc) then runDrop()
    elseif kbMatch(KB.InstaReset, kc) then cursedInstaReset()
    elseif kbMatch(KB.TPFloor, kc) then runTPFloor()
    elseif kbMatch(KB.AutoTP, kc) then
        autoTPEnabled = not autoTPEnabled
        if autoTPEnabled then startAutoTP() else stopAutoTP() end
        if setAutoTPVisual then setAutoTPVisual(autoTPEnabled) end
        if mobBtnRefs.autoTP then mobBtnRefs.autoTP(autoTPEnabled) end
        saveConfig()
    elseif kbMatch(KB.AutoLeft, kc) then
        autoLeftEnabled = not autoLeftEnabled
        if autoLeftEnabled then
            if autoRightEnabled then autoRightEnabled = false; stopAutoRight(); if autoRightSetVisual then autoRightSetVisual(false) end end
            if tpLockEnabled then toggleTPLock() end
            if batV2Enabled then toggleBatV2() end
            startAutoLeft()
            if autoLeftSetVisual then autoLeftSetVisual(true) end
            if mobBtnRefs.autoLeft then mobBtnRefs.autoLeft(true) end
        else
            stopAutoLeft()
            if autoLeftSetVisual then autoLeftSetVisual(false) end
            if mobBtnRefs.autoLeft then mobBtnRefs.autoLeft(false) end
        end
        saveConfig()
    elseif kbMatch(KB.AutoRight, kc) then
        autoRightEnabled = not autoRightEnabled
        if autoRightEnabled then
            if autoLeftEnabled then autoLeftEnabled = false; stopAutoLeft(); if autoLeftSetVisual then autoLeftSetVisual(false) end end
            if tpLockEnabled then toggleTPLock() end
            if batV2Enabled then toggleBatV2() end
            startAutoRight()
            if autoRightSetVisual then autoRightSetVisual(true) end
            if mobBtnRefs.autoRight then mobBtnRefs.autoRight(true) end
        else
            stopAutoRight()
            if autoRightSetVisual then autoRightSetVisual(false) end
            if mobBtnRefs.autoRight then mobBtnRefs.autoRight(false) end
        end
        saveConfig()
    elseif kbMatch(KB.TPLock, kc) then
        if batV2Enabled then toggleBatV2() end
        toggleTPLock()
    elseif kbMatch(KB.GuiHide, kc) then
        if mainFrame then mainFrame.Visible = not mainFrame.Visible end
    elseif kbMatch(KB.AutoBat, kc) then
        if not autoBatEnabled then
            autoBatEnabled = true; queueAutoBatStart(); if autoBatSetVisual then autoBatSetVisual(true) end
            if mobBtnRefs.autoBat then mobBtnRefs.autoBat(true) end
        else
            autoBatEnabled = false; disableAutoBat(); if autoBatSetVisual then autoBatSetVisual(false) end
            if mobBtnRefs.autoBat then mobBtnRefs.autoBat(false) end
        end
        saveConfig()
    elseif kbMatch(KB.Aimbot2, kc) then
        aimbot2Enabled = not aimbot2Enabled
        setAimbot2(aimbot2Enabled)
        if mobBtnRefs.aimbot2 then mobBtnRefs.aimbot2(aimbot2Enabled) end
        saveConfig()
    elseif kbMatch(KB.AntiDesync, kc) then
        antiDesyncAimbotEnabled = not antiDesyncAimbotEnabled
        setAntiDesyncAimbot(antiDesyncAimbotEnabled)
        if mobBtnRefs.antiDesync then mobBtnRefs.antiDesync(antiDesyncAimbotEnabled) end
        saveConfig()
    end
end)


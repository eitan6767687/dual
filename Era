        local tb=Instance.new("TextBox",row); tb.Size=UDim2.new(0,w or 50,0,22); tb.Position=UDim2.new(1,-(xOff or 56),0.5,-11)
        tb.BackgroundColor3=BH_INP; tb.BorderSizePixel=0; tb.Text=tostring(default); tb.TextColor3=BH_W
        tb.Font=Enum.Font.GothamBold; tb.TextSize=11; tb.ClearTextOnFocus=false; tb.ZIndex=5; mkCorner(tb,5)
        local bs=mkStroke(tb,BH_STR,1)
        tb.Focused:Connect(function() TweenService:Create(bs,TweenInfo.new(0.12),{Color=BH_BLUE,Transparency=0.2}):Play() end)
        tb.FocusLost:Connect(function()
            TweenService:Create(bs,TweenInfo.new(0.12),{Color=BH_STR,Transparency=0}):Play()
            if cb then local n=tonumber(tb.Text); if n then cb(n) else tb.Text=tostring(default) end end
        end)
        return tb
    end

    -- mkKB: keybind button, registers in keybindBtnRefs if keyName given
    local function mkKB(row, kRef, keyName, xOff, cb)
        local btn=Instance.new("TextButton",row); btn.Size=UDim2.new(0,46,0,22); btn.Position=UDim2.new(1,-(xOff or 52),0.5,-11)
        btn.BackgroundColor3=BH_INP; btn.BorderSizePixel=0; btn.ZIndex=5; btn.AutoButtonColor=false
        btn.Text=getKeyDisplayName(kRef); btn.TextColor3=BH_W; btn.Font=Enum.Font.GothamBold; btn.TextSize=9
        mkCorner(btn,5); mkStroke(btn,BH_STR,1)
        if keyName then keybindBtnRefs[keyName]=btn end
        local li=false; local lc
        btn.Activated:Connect(function()
            if li then li=false; if lc then lc:Disconnect(); lc=nil end; btn.Text=getKeyDisplayName(kRef); btn.TextColor3=BH_W; return end
            li=true; btn.Text="ֲ·ֲ·ֲ·"; btn.TextColor3=BH_BLUE
            lc=UIS.InputBegan:Connect(function(inp)
                if not li then return end
                if inp.UserInputType~=Enum.UserInputType.Keyboard and not inp.UserInputType.Name:find("Gamepad") then return end
                if inp.KeyCode==Enum.KeyCode.Escape then li=false; if lc then lc:Disconnect(); lc=nil end; btn.Text=getKeyDisplayName(kRef); btn.TextColor3=BH_W; return end
                if inp.KeyCode==Enum.KeyCode.Unknown then return end
                li=false; if lc then lc:Disconnect(); lc=nil end
                if cb then cb(inp.KeyCode) end
                btn.Text=getKeyDisplayName(inp.KeyCode); btn.TextColor3=BH_W
            end)
        end)
        return btn
    end


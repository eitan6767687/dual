 local function loadConfig()
     local has = false
     pcall(function() has = _isfile(CONFIG_FILE) end)
     if not has then return end
     local raw
     pcall(function() raw = _readfile(CONFIG_FILE) end)
     if not raw then return end
     local cfg
     local ok = pcall(function() cfg = HttpService:JSONDecode(raw) end)
     if not ok or not cfg then return end

     if cfg.normalSpeed then State.normalSpeed = cfg.normalSpeed end
     if cfg.carrySpeed then State.carrySpeed = cfg.carrySpeed end
     if cfg.aimbotSpeed then State.aimbotSpeed = cfg.aimbotSpeed end
     if cfg.horizPred   then State.horizPred   = cfg.horizPred   end
     if cfg.vertPred    then State.vertPred    = cfg.vertPred    end
     if cfg.jukeHeight and cfg.jukeHeight >= 1 and cfg.jukeHeight <= 100 then jukeHeight = cfg.jukeHeight end
     -- toggle states
     if cfg.tog_uiLocked      ~= nil then State.uiLocked            = cfg.tog_uiLocked      end
     if cfg.tog_darkMode      ~= nil then State.darkModeEnabled    = cfg.tog_darkMode      end
     if cfg.tog_espEnabled    ~= nil then State.espEnabled          = cfg.tog_espEnabled    end
     if cfg.tog_autoSteal     ~= nil then State.autoStealEnabled    = cfg.tog_autoSteal     end
     if cfg.stealRadius       ~= nil then State.stealRadius         = tonumber(cfg.stealRadius) or 63  end
     if cfg.stealSpeed        ~= nil then State.stealSpeed          = tonumber(cfg.stealSpeed)  or 1.3 end
     if cfg.tog_antiRagdoll   ~= nil then State.antiRagdollEnabled  = cfg.tog_antiRagdoll   end
     if cfg.tog_infJump       ~= nil then State.infJumpEnabled      = cfg.tog_infJump       end
     if cfg.infJumpMode == "manual" or cfg.infJumpMode == "hold" then State.infJumpMode = cfg.infJumpMode end
     if cfg.autoTpDownEnabled ~= nil then State.autoTpDownEnabled  = cfg.autoTpDownEnabled end
     if cfg.autoTpDownY       ~= nil then State.autoTpDownY        = cfg.autoTpDownY       end
     if cfg.tog_medusaCounter ~= nil then State.medusaCounterEnabled= cfg.tog_medusaCounter end
     if cfg.tog_batCounter    ~= nil then State.batCounterEnabled   = cfg.tog_batCounter    end
     if cfg.tog_unwalk        ~= nil then State.unwalkEnabled       = cfg.tog_unwalk        end
     if cfg.tog_fpsBoost      ~= nil then State.fpsBoostEnabled     = cfg.tog_fpsBoost      end
    if cfg.tog_purpleSky     ~= nil then State.purpleSkyEnabled    = cfg.tog_purpleSky     end
      if cfg.tog_laggerEnabled ~= nil then State.laggerEnabled      = cfg.tog_laggerEnabled end
     if cfg.tog_carryMode    ~= nil then State.speedToggled        = cfg.tog_carryMode     end
     if cfg.tog_autoLeft     ~= nil then State.autoLeftEnabled     = cfg.tog_autoLeft      end
     if cfg.tog_autoRight    ~= nil then State.autoRightEnabled    = cfg.tog_autoRight     end
     if cfg.tog_batAimbot    ~= nil then State.batAimbotToggled    = cfg.tog_batAimbot     end
     if cfg.tog_autoSwing    ~= nil then State.autoSwingEnabled    = cfg.tog_autoSwing     end
     if cfg.tog_hideButtons  ~= nil then State.hideButtonsEnabled  = cfg.tog_hideButtons   end
     if cfg.tog_autoCarry    ~= nil then State.autoCarryEnabled    = cfg.tog_autoCarry     end
     if cfg.laggerSpeed then State.laggerSpeed = cfg.laggerSpeed end
     if cfg.animName then _savedAnimName = cfg.animName end

 local _menuAnimating = false

 local function showMainWindow()
     if _menuAnimating then return end
     _menuAnimating = true
     mainOuter.Size = UDim2.new(0, WIN_W, 0, 0)
     mainOuter.Visible = true
     f1BarDot.BackgroundColor3 = Color3.fromRGB(80, 220, 130)
     TweenService:Create(mainOuter, TweenInfo.new(0.32, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
         Size = UDim2.new(0, WIN_W, 0, WIN_H)
     }):Play()
     task.delay(0.35, function() _menuAnimating = false end)
 end

 local function hideMainWindow()
     if _menuAnimating then return end
     _menuAnimating = true
     f1BarDot.BackgroundColor3 = Color3.fromRGB(80, 80, 80)
     local t = TweenService:Create(mainOuter, TweenInfo.new(0.22, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
         Size = UDim2.new(0, WIN_W, 0, 0)
     })
     t:Play()
     t.Completed:Connect(function()
         mainOuter.Visible = false
         mainOuter.Size = UDim2.new(0, WIN_W, 0, WIN_H)
         _menuAnimating = false
     end)
 end



 local startJukeLoop, stopJukeLoop
 do
     local jukeLoopConn = nil
     local function doJukeSingle()
         local c = LP.Character
         local hrp = c and c:FindFirstChild("HumanoidRootPart")
         if not hrp then return end
         local startY = hrp.Position.Y
         local done = false
         local conn
         conn = RunService.Heartbeat:Connect(function()
             local h = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
             if not h then conn:Disconnect(); done = true; return end
             if h.Position.Y - startY >= jukeHeight then
                 -- Reached target height ג€” TP down instantly like doTpDown
                 conn:Disconnect()
                 pcall(function()
                     local rp = RaycastParams.new()
                     rp.FilterDescendantsInstances = {c}
                     rp.FilterType = Enum.RaycastFilterType.Exclude
                     local res = workspace:Raycast(h.Position, Vector3.new(0, -1000, 0), rp)
                     if res then
                         h.CFrame = CFrame.new(res.Position + Vector3.new(0, h.Size.Y / 2 + 0.5, 0))
                         h.AssemblyLinearVelocity = Vector3.zero
                     end
                 end)
                 done = true
             else
                 pcall(function() h.AssemblyLinearVelocity = Vector3.new(0, 50, 0) end)
             end
         end)
         local t = tick()
         while not done and tick() - t < 6 do
             task.wait()
         end
         pcall(function() conn:Disconnect() end)
     end
     startJukeLoop = function()
         if jukeLoopConn then return end
         jukeLoopConn = task.spawn(function()
             while jukeEnabled do
                 doJukeSingle()
                 if jukeEnabled then
                     task.wait(0.2)
                 end
             end
             jukeLoopConn = nil
         end)
     end

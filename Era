    startAntiRagdoll = function()
        if Conns.antiRag then return end
        -- Improved anti-ragdoll: destroys BallSocketConstraints, resets Motor6D joints,
        -- checks server-set RagdollEndTime attribute, resets velocity and unanchors root.
        Conns.antiRag = RunService.Heartbeat:Connect(function()
            if not State.antiRagdollEnabled then return end
            local char = LP.Character
            if not char then return end
            local hum2 = char:FindFirstChildOfClass("Humanoid")
            local root = char:FindFirstChild("HumanoidRootPart")
            if not (hum2 and root) then return end
            local s = hum2:GetState()
            local isRag = (s == Enum.HumanoidStateType.Physics
                or s == Enum.HumanoidStateType.Ragdoll
                or s == Enum.HumanoidStateType.FallingDown)
            -- Also respect server-set ragdoll end time attribute
            local endTime = LP:GetAttribute("RagdollEndTime")
            if endTime and (endTime - workspace:GetServerTimeNow()) > 0 then
                isRag = true
            end
            if isRag then
                -- Clear the server ragdoll timer immediately
                pcall(function() LP:SetAttribute("RagdollEndTime", workspace:GetServerTimeNow()) end)
                -- Destroy ragdoll physics constraints and their attachments
                for _, d in ipairs(char:GetDescendants()) do
                    if d:IsA("BallSocketConstraint")
                        or (d:IsA("Attachment") and d.Name:find("RagdollAttachment")) then
                        pcall(function() d:Destroy() end)
                    end
                end
                -- Re-enable all disabled Motor6D joints (restores character rig)
                for _, obj in ipairs(char:GetDescendants()) do
                    if obj:IsA("Motor6D") and obj.Enabled == false then
                        obj.Enabled = true
                    end
                end
                if hum2.Health > 0 then
                    hum2:ChangeState(Enum.HumanoidStateType.Running)
                end
                workspace.CurrentCamera.CameraSubject = hum2
                root.Anchored = false
                root.AssemblyLinearVelocity = Vector3.zero
                root.AssemblyAngularVelocity = Vector3.zero
            end
        end)
    end
